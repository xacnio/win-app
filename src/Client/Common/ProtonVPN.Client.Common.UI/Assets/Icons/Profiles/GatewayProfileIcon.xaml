<base:ProfileIconUserControl x:Class="ProtonVPN.Client.Common.UI.Assets.Icons.Profiles.GatewayProfileIcon"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:base="using:ProtonVPN.Client.Common.UI.Assets.Icons.Base"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             x:DefaultBindMode="OneWay"
                             mc:Ignorable="d">

    <UserControl.Resources>
        <LinearGradientBrush x:Key="DarkGradientBrush"
                             MappingMode="RelativeToBoundingBox"
                             StartPoint="0,0"
                             EndPoint="0,1">
            <LinearGradientBrush.GradientStops>
                <GradientStopCollection>
                    <GradientStop Offset="0.6"
                                  Color="{x:Bind AccentColor, Converter={StaticResource ProfileColorToDarkColorConverter}, ConverterParameter=0}" />
                    <GradientStop Offset="1"
                                  Color="{x:Bind AccentColor, Converter={StaticResource ProfileColorToDarkColorConverter}, ConverterParameter=90}" />
                </GradientStopCollection>
            </LinearGradientBrush.GradientStops>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="LightGradientBrush"
                             MappingMode="RelativeToBoundingBox"
                             StartPoint="0,0"
                             EndPoint="0.03,1">
            <LinearGradientBrush.GradientStops>
                <GradientStopCollection>
                    <GradientStop Offset="0"
                                  Color="{x:Bind AccentColor, Converter={StaticResource ProfileColorToLightColorConverter}, ConverterParameter=180}" />
                    <GradientStop Offset="0.8"
                                  Color="{x:Bind AccentColor, Converter={StaticResource ProfileColorToLightColorConverter}, ConverterParameter=0}" />
                </GradientStopCollection>
            </LinearGradientBrush.GradientStops>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SecondDarkGradientBrush"
                             MappingMode="RelativeToBoundingBox"
                             StartPoint="0,0"
                             EndPoint="1,0">
            <LinearGradientBrush.GradientStops>
                <GradientStopCollection>
                    <GradientStop Offset="0"
                                  Color="{x:Bind AccentColor, Converter={StaticResource ProfileColorToDarkColorConverter}, ConverterParameter=200}" />
                    <GradientStop Offset="1"
                                  Color="{x:Bind AccentColor, Converter={StaticResource ProfileColorToDarkColorConverter}, ConverterParameter=150}" />
                </GradientStopCollection>
            </LinearGradientBrush.GradientStops>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ThirdDarkGradientBrush"
                             MappingMode="RelativeToBoundingBox"
                             StartPoint="0,0"
                             EndPoint="1,0">
            <LinearGradientBrush.GradientStops>
                <GradientStopCollection>
                    <GradientStop Offset="0"
                                  Color="{x:Bind AccentColor, Converter={StaticResource ProfileColorToDarkColorConverter}, ConverterParameter=120}" />
                    <GradientStop Offset="1"
                                  Color="{x:Bind AccentColor, Converter={StaticResource ProfileColorToDarkColorConverter}, ConverterParameter=160}" />
                </GradientStopCollection>
            </LinearGradientBrush.GradientStops>
        </LinearGradientBrush>

    </UserControl.Resources>

    <Viewbox Stretch="{x:Bind Stretch}">
        <Canvas Width="36"
                Height="24">

            <Rectangle Canvas.Left="4"
                       Canvas.Top="11"
                       Width="28"
                       Height="2"
                       Fill="{x:Bind AccentColor, Converter={StaticResource ProfileColorToBrushConverter}}" />
            <Rectangle Canvas.Left="4"
                       Canvas.Top="11"
                       Width="28"
                       Height="2"
                       Fill="{StaticResource SecondDarkGradientBrush}" />
            <Rectangle Canvas.Left="1"
                       Canvas.Top="1"
                       Width="34"
                       Height="10"
                       Fill="{x:Bind AccentColor, Converter={StaticResource ProfileColorToBrushConverter}}"
                       RadiusX="3"
                       RadiusY="3" />
            <Rectangle Canvas.Left="1"
                       Canvas.Top="1"
                       Width="34"
                       Height="10"
                       Fill="{StaticResource DarkGradientBrush}"
                       RadiusX="3"
                       RadiusY="3" />
            <Rectangle Canvas.Left="1"
                       Canvas.Top="1"
                       Width="34"
                       Height="10"
                       Fill="{StaticResource LightGradientBrush}"
                       RadiusX="3"
                       RadiusY="3" />
            <Rectangle Canvas.Left="1"
                       Canvas.Top="13"
                       Width="34"
                       Height="10"
                       Fill="{x:Bind AccentColor, Converter={StaticResource ProfileColorToBrushConverter}}"
                       RadiusX="3"
                       RadiusY="3" />
            <Rectangle Canvas.Left="1"
                       Canvas.Top="13"
                       Width="34"
                       Height="10"
                       Fill="{StaticResource DarkGradientBrush}"
                       RadiusX="3"
                       RadiusY="3" />
            <Rectangle Canvas.Left="1"
                       Canvas.Top="13"
                       Width="34"
                       Height="10"
                       Fill="{StaticResource LightGradientBrush}"
                       RadiusX="3"
                       RadiusY="3" />
            <Rectangle Canvas.Left="5"
                       Canvas.Top="5"
                       Width="14"
                       Height="2"
                       Fill="{StaticResource ThirdDarkGradientBrush}"
                       RadiusX="1"
                       RadiusY="1" />
            <Rectangle Canvas.Left="5"
                       Canvas.Top="17"
                       Width="14"
                       Height="2"
                       Fill="{StaticResource ThirdDarkGradientBrush}"
                       RadiusX="1"
                       RadiusY="1" />
            <Ellipse Canvas.Left="25"
                     Canvas.Top="5"
                     Width="2"
                     Height="2"
                     Fill="white" />
            <Ellipse Canvas.Left="25"
                     Canvas.Top="17"
                     Width="2"
                     Height="2"
                     Fill="white" />
            <Ellipse Canvas.Left="29"
                     Canvas.Top="5"
                     Width="2"
                     Height="2"
                     Fill="white" />
            <Ellipse Canvas.Left="29"
                     Canvas.Top="17"
                     Width="2"
                     Height="2"
                     Fill="white" />
        </Canvas>
    </Viewbox>
</base:ProfileIconUserControl>
