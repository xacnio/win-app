<base:ProfileIconUserControl x:Class="ProtonVPN.Client.Common.UI.Assets.Icons.Profiles.BotProfileIcon"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:base="using:ProtonVPN.Client.Common.UI.Assets.Icons.Base"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:local="using:ProtonVPN.Client.Common.UI.Assets.Icons.Profiles"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             x:DefaultBindMode="OneWay"
                             mc:Ignorable="d">

    <UserControl.Resources>

        <LinearGradientBrush x:Key="DarkGradientBrush"
                             MappingMode="RelativeToBoundingBox"
                             StartPoint="0,0"
                             EndPoint="0,1">
            <LinearGradientBrush.GradientStops>
                <GradientStopCollection>
                    <GradientStop Offset="0.6"
                                  Color="{x:Bind AccentColor, Converter={StaticResource ProfileColorToDarkColorConverter}, ConverterParameter=0}" />
                    <GradientStop Offset="1"
                                  Color="{x:Bind AccentColor, Converter={StaticResource ProfileColorToDarkColorConverter}, ConverterParameter=90}" />
                </GradientStopCollection>
            </LinearGradientBrush.GradientStops>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SecondDarkGradientBrush"
                             MappingMode="RelativeToBoundingBox"
                             StartPoint="0,0"
                             EndPoint="0,1">
            <LinearGradientBrush.GradientStops>
                <GradientStopCollection>
                    <GradientStop Offset="0"
                                  Color="{x:Bind AccentColor, Converter={StaticResource ProfileColorToDarkColorConverter}, ConverterParameter=180}" />
                    <GradientStop Offset="1"
                                  Color="{x:Bind AccentColor, Converter={StaticResource ProfileColorToDarkColorConverter}, ConverterParameter=90}" />
                </GradientStopCollection>
            </LinearGradientBrush.GradientStops>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ShadowGradientBrush"
                             MappingMode="RelativeToBoundingBox"
                             StartPoint="0,0"
                             EndPoint="1,0">
            <LinearGradientBrush.GradientStops>
                <GradientStopCollection>
                    <GradientStop Offset="0"
                                  Color="{x:Bind AccentColor, Converter={StaticResource ProfileColorToDarkColorConverter}, ConverterParameter=0}" />
                    <GradientStop Offset="0.2"
                                  Color="{x:Bind AccentColor, Converter={StaticResource ProfileColorToDarkColorConverter}, ConverterParameter=160}" />
                    <GradientStop Offset="0.8"
                                  Color="{x:Bind AccentColor, Converter={StaticResource ProfileColorToDarkColorConverter}, ConverterParameter=160}" />
                    <GradientStop Offset="1"
                                  Color="{x:Bind AccentColor, Converter={StaticResource ProfileColorToDarkColorConverter}, ConverterParameter=0}" />
                </GradientStopCollection>
            </LinearGradientBrush.GradientStops>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="LightGradientBrush"
                             MappingMode="RelativeToBoundingBox"
                             StartPoint="0,0"
                             EndPoint="0.2,1">
            <LinearGradientBrush.GradientStops>
                <GradientStopCollection>
                    <GradientStop Color="{x:Bind AccentColor, Converter={StaticResource ProfileColorToLightColorConverter}, ConverterParameter=180}" />
                    <GradientStop Offset="1"
                                  Color="{x:Bind AccentColor, Converter={StaticResource ProfileColorToLightColorConverter}, ConverterParameter=0}" />
                </GradientStopCollection>
            </LinearGradientBrush.GradientStops>
        </LinearGradientBrush>

    </UserControl.Resources>

    <Viewbox Stretch="{x:Bind Stretch}">
        <Canvas Width="36"
                Height="24">
            <Rectangle Canvas.Left="1"
                       Canvas.Top="11"
                       Width="34"
                       Height="8"
                       Fill="{x:Bind AccentColor, Converter={StaticResource ProfileColorToBrushConverter}}"
                       RadiusX="2"
                       RadiusY="2" />
            <Rectangle Canvas.Left="1"
                       Canvas.Top="11"
                       Width="34"
                       Height="8"
                       Fill="{StaticResource ShadowGradientBrush}"
                       RadiusX="2"
                       RadiusY="2" />

            <Rectangle Canvas.Left="4"
                       Canvas.Top="6"
                       Width="28"
                       Height="18"
                       Fill="{x:Bind AccentColor, Converter={StaticResource ProfileColorToBrushConverter}}"
                       RadiusX="4"
                       RadiusY="4" />
            <Rectangle Canvas.Left="4"
                       Canvas.Top="6"
                       Width="28"
                       Height="18"
                       Fill="{StaticResource DarkGradientBrush}"
                       RadiusX="4"
                       RadiusY="4" />
            <Rectangle Canvas.Left="4"
                       Canvas.Top="6"
                       Width="28"
                       Height="18"
                       Fill="{StaticResource LightGradientBrush}"
                       RadiusX="4"
                       RadiusY="4" />

            <Path Data="M17.5 3H18.5L19 6H17L17.5 3Z"
                  Fill="{x:Bind AccentColor, Converter={StaticResource ProfileColorToBrushConverter}}" />
            <Path Data="M17.5 3H18.5L19 6H17L17.5 3Z"
                  Fill="{StaticResource SecondDarkGradientBrush}" />

            <Ellipse Canvas.Left="16"
                     Canvas.Top="0"
                     Width="4"
                     Height="4"
                     Fill="{x:Bind AccentColor, Converter={StaticResource ProfileColorToBrushConverter}}" />
            <Ellipse Canvas.Left="16"
                     Canvas.Top="0"
                     Width="4"
                     Height="4"
                     Fill="{StaticResource LightGradientBrush}" />
            <Ellipse Canvas.Left="10.5"
                     Canvas.Top="11.5"
                     Width="4"
                     Height="4"
                     Fill="white" />
            <Ellipse Canvas.Left="21.5"
                     Canvas.Top="11.5"
                     Width="4"
                     Height="4"
                     Fill="white" />
            <Path Data="M15 19V19C16.9473 19.6491 19.0527 19.6491 21 19V19"
                  Stroke="white"
                  StrokeEndLineCap="round"
                  StrokeStartLineCap="round"
                  StrokeThickness="1.5" />
        </Canvas>
    </Viewbox>
</base:ProfileIconUserControl>
