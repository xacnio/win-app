<Page x:Class="ProtonVPN.Client.UI.Main.Settings.Pages.Advanced.CustomDnsServersPageView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
      xmlns:pathicons="using:ProtonVPN.Client.Common.UI.Assets.Icons.PathIcons"
      xmlns:custom="using:ProtonVPN.Client.Common.UI.Controls.Custom"
      xmlns:networking="using:ProtonVPN.Common.Core.Networking"
      x:DefaultBindMode="OneWay"
      NavigationCacheMode="Required"
      mc:Ignorable="d">

    <Page.Resources>
        <DataTemplate x:Key="Ipv6EnabledNetworkAddressTemplate"
                      x:DataType="networking:NetworkAddress">
            <Border Padding="8,2"
                    Background="{ThemeResource InteractionDefaultColorBrush}"
                    CornerRadius="4">
                <TextBlock Style="{StaticResource BodyTextBlockStyle}"
                           Text="{x:Bind}"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="Ipv6DisabledNetworkAddressTemplate"
                      x:DataType="networking:NetworkAddress">
            <Border Padding="8,2"
                    Background="{ThemeResource InteractionDefaultColorBrush}"
                    CornerRadius="4">
                <TextBlock Opacity="{x:Bind IsIpV6, Converter={StaticResource BooleanToReducedOpacityConverter}}"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Text="{x:Bind}"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap" />
            </Border>
        </DataTemplate>
    </Page.Resources>

    <custom:SettingsPageContentControl x:Name="PageContentHost"
                                       ApplyCommand="{x:Bind ViewModel.ApplyCommand, Mode=OneTime}"
                                       ApplyCommandText="{x:Bind ViewModel.ApplyCommandText}"
                                       BackCommand="{x:Bind ViewModel.NavigateBackCommand, Mode=OneTime}"
                                       CloseCommand="{x:Bind ViewModel.CloseCommand, Mode=OneTime}"
                                       IsBackButtonVisible="{x:Bind ViewModel.CanGoBack}">

        <custom:SettingsPageContentControl.PageHeader>
            <custom:SettingsPageHeaderContentControl Header="{x:Bind ViewModel.Title}" />
        </custom:SettingsPageContentControl.PageHeader>

        <StackPanel x:Name="ContentArea"
                    Spacing="16">
            <toolkit:SettingsCard Description="{x:Bind ViewModel.Localizer.Get('Settings_Connection_Advanced_CustomDnsServers_Description')}"
                                  Header="{x:Bind ViewModel.Localizer.Get('Settings_Connection_Advanced_CustomDnsServers')}"
                                  IsTabStop="False"
                                  Style="{StaticResource DefaultSettingsCardStyle}">
                <ToggleSwitch AutomationProperties.AutomationId="CustomDnsToggle"
                              IsOn="{x:Bind ViewModel.IsCustomDnsServersEnabled, Mode=TwoWay}"
                              Style="{StaticResource ToggleSwitchStyle}" />
            </toolkit:SettingsCard>

            <StackPanel Spacing="8"
                        Visibility="{x:Bind ViewModel.IsCustomDnsServersEnabled}">

                <Grid HorizontalAlignment="Left">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Foreground="{ThemeResource TextWeakColorBrush}"
                               Text="{x:Bind ViewModel.DnsServersHeader}"
                               TextTrimming="CharacterEllipsis" />

                    <custom:GhostButton Grid.Column="1"
                                        Margin="8,-8,0,-8"
                                        HorizontalAlignment="Left"
                                        AutomationProperties.AutomationId="ShowIpv6DisabledWarningButton"
                                        AutomationProperties.FullDescription="{x:Bind ViewModel.Localizer.Get('Overlay_Ipv6Disabled_Description')}"
                                        AutomationProperties.Name="{x:Bind ViewModel.Localizer.Get('Overlay_Ipv6Disabled_Title')}"
                                        Command="{x:Bind ViewModel.TriggerIpv6DisabledWarningCommand, Mode=OneTime}"
                                        ToolTipService.ToolTip="{x:Bind ViewModel.Localizer.Get('Overlay_Ipv6Disabled_Title')}"
                                        Visibility="{x:Bind ViewModel.HasIpv6DnsServersWhileIpv6Disabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <custom:GhostButton.LeftIcon>
                            <pathicons:ExclamationTriangleFilled Foreground="{ThemeResource SignalWarningColorBrush}"
                                                                 Size="Pixels16" />
                        </custom:GhostButton.LeftIcon>
                    </custom:GhostButton>
                </Grid>

                <toolkit:SettingsCard AutomationProperties.AutomationId="DnsServersSelectorSettingsCard"
                                      Command="{x:Bind ViewModel.SelectCustomDnsServersCommand, Mode=OneTime}"
                                      IsClickEnabled="True"
                                      Style="{StaticResource DefaultSettingsCardStyle}">

                    <toolkit:SettingsCard.Header>

                        <Grid>
                            <TextBlock Foreground="{ThemeResource TextHintColorBrush}"
                                       Text="{x:Bind ViewModel.Localizer.Get('Settings_Connection_Advanced_CustomDnsServers_Select')}"
                                       Visibility="{x:Bind ViewModel.HasSelectedDnsServers, Converter={StaticResource NotBooleanToVisibilityConverter}}" />

                            <ScrollViewer MaxHeight="90"
                                          Style="{StaticResource OffsetScrollViewer}"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsControl VerticalAlignment="Center"
                                              ItemTemplate="{x:Bind SelectDnsServerItemTemplate(ViewModel.HasIpv6DnsServersWhileIpv6Disabled)}"
                                              ItemsSource="{x:Bind ViewModel.SelectedDnsServers}"
                                              Visibility="{x:Bind ViewModel.HasSelectedDnsServers, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <toolkit:WrapPanel HorizontalSpacing="8"
                                                               Orientation="Horizontal"
                                                               VerticalSpacing="8" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>

                    </toolkit:SettingsCard.Header>

                    <toolkit:SettingsCard.ActionIcon>
                        <pathicons:ChevronRight />
                    </toolkit:SettingsCard.ActionIcon>
                </toolkit:SettingsCard>

                <TextBlock Foreground="{ThemeResource TextWeakColorBrush}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Text="{x:Bind ViewModel.Localizer.Get('Settings_Connection_Advanced_CustomDnsServers_Footer')}" />
            </StackPanel>
        </StackPanel>
    </custom:SettingsPageContentControl>
</Page>