<custom:MessageContentDialog x:Class="ProtonVPN.Client.UI.Overlays.Selection.AppSelectorOverlayView"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             xmlns:pathIcons="using:ProtonVPN.Client.Common.UI.Assets.Icons.PathIcons"
                             xmlns:ap="using:ProtonVPN.Client.Common.UI.AttachedProperties"
                             xmlns:custom="using:ProtonVPN.Client.Common.UI.Controls.Custom"
                             xmlns:models="using:ProtonVPN.Client.Core.Models"
                             Title="{x:Bind ViewModel.Title}"
                             Padding="{StaticResource NarrowMessageContentDialogPadding}"
                             x:DefaultBindMode="OneWay"
                             CloseButtonText="{x:Bind ViewModel.Localizer.Get('Common_Actions_Cancel')}"
                             PrimaryButtonText="{x:Bind ViewModel.Localizer.Get('Settings_Common_Apply')}"
                             Style="{StaticResource MessageContentDialogStyle}"
                             IsPrimaryButtonEnabled="{x:Bind ViewModel.HasChanges}"
                             mc:Ignorable="d">


    <custom:MessageContentDialog.Resources>
        <x:Double x:Key="ContentDialogWidth">500</x:Double>
        <x:Double x:Key="MaximumContentDialogWidth">620.0</x:Double>
    </custom:MessageContentDialog.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="0,0,8,16"
                   Style="{StaticResource CaptionTextBlockStyle}"
                   Text="{x:Bind ViewModel.Description}"
                   TextWrapping="Wrap" />

        <ListView x:Name="AppsListView" 
                  Grid.Row="1"
                  MaxHeight="250"
                  Margin="0,0,12,16"
                  DataContext="{x:Bind ViewModel}"
                  ItemsSource="{x:Bind ViewModel.Apps}"
                  SelectionMode="None"
                  Style="{StaticResource GhostListViewStyle}"
                  Visibility="{x:Bind ViewModel.HasApps, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:SelectableTunnelingApp">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="proxy"
                                ap:AncestorSource.AncestorType="ListView" />

                        <Border Grid.Column="0"
                                Background="Transparent" HorizontalAlignment="Left"
                                ToolTipService.ToolTip="{x:Bind Value.AppPath}">
                            <CheckBox AutomationProperties.AutomationId="AppItemToggle"
                                      IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                      IsEnabled="{x:Bind Value.IsValid}">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Image Grid.Column="0"
                                           Width="20"
                                           Height="20"
                                           Source="{x:Bind Value.AppIcon}"
                                           Visibility="{x:Bind Value.IsValid, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind Value.AppName}"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{x:Bind Value.IsValid, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                    <pathIcons:ExclamationCircleFilled Grid.Column="0"
                                                                       Foreground="{ThemeResource SignalDangerColorBrush}"
                                                                       Opacity="0.6"
                                                                       Size="Pixels20"
                                                                       Visibility="{x:Bind Value.IsValid, Converter={StaticResource NotBooleanToVisibilityConverter}}" />
                                    <TextBlock Grid.Column="1"
                                               Foreground="{ThemeResource SignalDangerColorBrush}"
                                               Opacity="0.6"
                                               Text="{x:Bind Value.AppName}"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{x:Bind Value.IsValid, Converter={StaticResource NotBooleanToVisibilityConverter}}" />

                                </Grid>
                            </CheckBox>
                        </Border>

                        <custom:GhostButton Grid.Column="1"
                                            AutomationProperties.AutomationId="TrashIcon"
                                            AutomationProperties.Name="{Binding DataContext.DataContext.RemoveTooltip, ElementName=proxy}"
                                            Command="{Binding DataContext.DataContext.RemoveAppCommand, ElementName=proxy}"
                                            CommandParameter="{x:Bind Mode=OneTime}"
                                            ToolTipService.ToolTip="{Binding DataContext.DataContext.RemoveTooltip, ElementName=proxy}">
                            <custom:GhostButton.LeftIcon>
                                <pathIcons:Trash />
                            </custom:GhostButton.LeftIcon>
                        </custom:GhostButton>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Button Grid.Row="3"
                AutomationProperties.AutomationId="AddButton"
                Command="{x:Bind ViewModel.AddAppCommand, Mode=OneTime}"
                Content="{x:Bind ViewModel.Localizer.Get('Common_Actions_Add')}" />
    </Grid>
</custom:MessageContentDialog>