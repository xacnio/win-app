<custom:MessageContentDialog x:Class="ProtonVPN.Client.UI.Overlays.Selection.IpSelectorOverlayView"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:ap="using:ProtonVPN.Client.Common.UI.AttachedProperties"
                             xmlns:custom="using:ProtonVPN.Client.Common.UI.Controls.Custom"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             xmlns:models="using:ProtonVPN.Client.Core.Models"
                             xmlns:pathIcons="using:ProtonVPN.Client.Common.UI.Assets.Icons.PathIcons"
                             Title="{x:Bind ViewModel.Title}"
                             Padding="{StaticResource NarrowMessageContentDialogPadding}"
                             x:DefaultBindMode="OneWay"
                             CloseButtonText="{x:Bind ViewModel.Localizer.Get('Common_Actions_Cancel')}"
                             PrimaryButtonText="{x:Bind ViewModel.Localizer.Get('Settings_Common_Apply')}"
                             Style="{StaticResource MessageContentDialogStyle}"
                             AutomationProperties.AutomationId="IpSelectorOverlay"
                             IsPrimaryButtonEnabled="{x:Bind ViewModel.HasChanges}"
                             mc:Ignorable="d">

    <custom:MessageContentDialog.Resources>
        <x:Double x:Key="ContentDialogWidth">500</x:Double>
        <x:Double x:Key="MaximumContentDialogWidth">620.0</x:Double>
    </custom:MessageContentDialog.Resources>

    <Grid ColumnSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   Margin="0,0,8,16"
                   Style="{StaticResource CaptionTextBlockStyle}"
                   Text="{x:Bind ViewModel.Description}"
                   TextWrapping="Wrap" />

        <TextBox Grid.Row="1"
                 Grid.Column="0"
                 MinHeight="34"
                 VerticalAlignment="Top"
                 ap:FieldValidation.ErrorMessage="{x:Bind ViewModel.CurrentAddressError}"
                 ap:FieldValidation.HasErrors="{x:Bind ViewModel.CurrentAddressError, Converter={StaticResource NotNullToBooleanConverter}}"
                 AutomationProperties.AutomationId="IpAddressTextBox"
                 Description="{x:Bind ViewModel.Caption}"
                 KeyDown="{x:Bind ViewModel.OnCurrentAddressKeyDownHandler, Mode=OneTime}"
                 PlaceholderText="{x:Bind ViewModel.Localizer.Get('Settings_Common_IpAddresses_Watermark')}"
                 Style="{StaticResource ValidationTextBoxStyle}"
                 Text="{x:Bind ViewModel.CurrentAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <Button Grid.Row="1"
                Grid.Column="1"
                Margin="0,0,8,0"
                VerticalAlignment="Top"
                AutomationProperties.AutomationId="AddButton"
                Command="{x:Bind ViewModel.AddAddressCommand, Mode=OneTime}"
                Content="{x:Bind ViewModel.Localizer.Get('Common_Actions_Add')}" 
                Style="{ThemeResource PrimaryButtonStyle}"/>

        <ListView x:Name="AddressesListView"
                  Grid.Row="2"
                  Grid.Column="0"
                  Grid.ColumnSpan="2"
                  MaxHeight="220"
                  Margin="0,16,12,0"
                  AllowDrop="{x:Bind ViewModel.CanReorder}"
                  CanReorderItems="{x:Bind ViewModel.CanReorder}"
                  DataContext="{x:Bind ViewModel}"
                  ItemsSource="{x:Bind ViewModel.Addresses, Mode=OneTime}"
                  ScrollViewer.VerticalScrollBarVisibility="Visible"
                  SelectionMode="None"
                  Style="{StaticResource GhostListViewStyle}"
                  Visibility="{x:Bind ViewModel.HasAddresses, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ListView.ItemContainerTransitions>
                <TransitionCollection>
                    <ReorderThemeTransition />
                </TransitionCollection>
            </ListView.ItemContainerTransitions>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:SelectableNetworkAddress">
                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="proxy"
                                ap:AncestorSource.AncestorType="ListView" />

                        <pathIcons:Dots Grid.Column="0"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        AutomationProperties.AutomationId="AddressItemDragHandle"
                                        Size="Pixels16"
                                        Visibility="{Binding DataContext.DataContext.IsDragDropEnabled, ElementName=proxy, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <CheckBox Grid.Column="1"
                                  Margin="0,0,8,0"
                                  AutomationProperties.AutomationId="AddressItemToggle"
                                  Content="{x:Bind Value}"
                                  IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />

                        <StackPanel Grid.Column="2"
                                    Margin="0,0,8,0"
                                    BorderBrush="{ThemeResource BorderWeakColorBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Orientation="Horizontal"
                                    Visibility="{Binding DataContext.DataContext.CanReorder, ElementName=proxy, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <custom:GhostButton AutomationProperties.AutomationId="MoveUpButton"
                                                AutomationProperties.Name="{Binding DataContext.DataContext.MoveUpTooltip, ElementName=proxy}"
                                                Command="{Binding DataContext.DataContext.MoveAddressUpCommand, ElementName=proxy}"
                                                CommandParameter="{x:Bind Mode=OneTime}"
                                                ToolTipService.ToolTip="{Binding DataContext.DataContext.MoveUpTooltip, ElementName=proxy}">
                                <custom:GhostButton.LeftIcon>
                                    <pathIcons:ChevronUpFilled />
                                </custom:GhostButton.LeftIcon>
                            </custom:GhostButton>
                            <custom:GhostButton AutomationProperties.AutomationId="MoveDownButton"
                                                AutomationProperties.Name="{Binding DataContext.DataContext.MoveDownTooltip, ElementName=proxy}"
                                                Command="{Binding DataContext.DataContext.MoveAddressDownCommand, ElementName=proxy}"
                                                CommandParameter="{x:Bind Mode=OneTime}"
                                                ToolTipService.ToolTip="{Binding DataContext.DataContext.MoveDownTooltip, ElementName=proxy}">
                                <custom:GhostButton.LeftIcon>
                                    <pathIcons:ChevronDownFilled />
                                </custom:GhostButton.LeftIcon>
                            </custom:GhostButton>
                        </StackPanel>

                        <custom:GhostButton Grid.Column="3"
                                            AutomationProperties.AutomationId="TrashIcon"
                                            AutomationProperties.Name="{Binding DataContext.DataContext.RemoveTooltip, ElementName=proxy}"
                                            Command="{Binding DataContext.DataContext.RemoveAddressCommand, ElementName=proxy}"
                                            CommandParameter="{x:Bind Mode=OneTime}"
                                            ToolTipService.ToolTip="{Binding DataContext.DataContext.RemoveTooltip, ElementName=proxy}">
                            <custom:GhostButton.LeftIcon>
                                <pathIcons:Trash />
                            </custom:GhostButton.LeftIcon>
                        </custom:GhostButton>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</custom:MessageContentDialog>